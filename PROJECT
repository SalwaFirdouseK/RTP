RTP|WEB SCRAPING AND CRAWLING
import com.sun.net.httpserver.HttpServer;
import com.sun.net.httpserver.HttpHandler;
import com.sun.net.httpserver.HttpExchange;

import org.jsoup.Jsoup;
import org.jsoup.nodes.Document;
import org.jsoup.nodes.Element;
import org.jsoup.select.Elements;



import java.io.*;
import java.net.InetSocketAddress;
import java.net.URLDecoder;
import java.nio.charset.StandardCharsets;


public class Server {

    public static void main(String[] args) throws Exception {

        // ✅ Safe port
        HttpServer server = HttpServer.create(new InetSocketAddress(7070), 0);

        server.createContext("/", new MyHandler());

        server.start();

        System.out.println("Server started at http://localhost:7070");
    }


    static class MyHandler implements HttpHandler {

        public void handle(HttpExchange exchange) throws IOException {

            String method = exchange.getRequestMethod();

            StringBuilder response = new StringBuilder();

            // 🔥 HTML START
            response.append("<html><head>");

            // ✅ FIX encoding
            response.append("<meta charset='UTF-8'>");

            response.append("<title>Web Scraper</title>");

            // 🎨 CSS
            response.append("<style>");
            response.append("body{font-family:Arial;background:#f4f4f4;text-align:center;}");
            response.append("input{padding:10px;width:300px;}");
            response.append("button{padding:10px 20px;background:#333;color:white;border:none;}");
            response.append("table{margin:auto;margin-top:20px;border-collapse:collapse;width:80%;background:white;}");
            response.append("th,td{padding:10px;border:1px solid #ddd;}");
            response.append("th{background:#333;color:white;}");
            response.append("</style>");

            response.append("</head><body>");


            // 🔥 TITLE
            response.append("<h2>Web Scraper</h2>");

            // 🔥 INPUT FORM
            response.append("<form method='POST'>");
            response.append("<input type='text' name='url' placeholder='Enter URL' required>");
            response.append("<button type='submit'>Scrape</button>");
            response.append("</form>");


            // 🔥 IF USER PRESSES BUTTON
            if (method.equalsIgnoreCase("POST")) {

                InputStream is = exchange.getRequestBody();
                String body = new String(is.readAllBytes(), StandardCharsets.UTF_8);

                String url = body.split("=")[1];
                url = URLDecoder.decode(url, "UTF-8");

                response.append("<h3>Results:</h3>");
                response.append("<table>");
                response.append("<tr><th>No</th><th>Title</th><th>Price</th></tr>");


                try {
                    Document doc = Jsoup.connect(url).get();
                    Elements books = doc.select("article.product_pod");

                    int count = 1;

                    for (Element book : books) {

                        String title = book.select("h3 a").attr("title");
                        String price = book.select("p.price_color").text();

                        response.append("<tr>");
                        response.append("<td>" + count + "</td>");
                        response.append("<td>" + title + "</td>");
                        response.append("<td>" + price + "</td>");
                        response.append("</tr>");

                        count++;
                    }

                } catch (Exception e) {
                    response.append("<p style='color:red;'>Error fetching data</p>");
                }
                response.append("</table>");
            }

            response.append("</body></html>");

            // 🔥 SEND RESPONSE
            exchange.getResponseHeaders().add("Content-Type", "text/html; charset=UTF-8");
            exchange.sendResponseHeaders(200, 0);

            OutputStream os = exchange.getResponseBody();
            os.write(response.toString().getBytes(StandardCharsets.UTF_8));
            os.close();
        }
    }
}
               
